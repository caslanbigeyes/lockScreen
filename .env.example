# LemonSqueezy 配置
# 在 LemonSqueezy 后台获取这些信息

# Store ID（商店 ID）
LEMONSQUEEZY_STORE_ID=your_store_id_here

# 购买页面 URL
# 方案 1：使用闲鱼链接（推荐，最简单）
PURCHASE_URL=https://www.goofish.com/item?id=1026146077023

# 方案 2：使用自建购买页面
# PURCHASE_URL=https://buy.focusguard.com

# 方案 3：使用 LemonSqueezy
# PURCHASE_URL=https://focusguard.lemonsqueezy.com/checkout/buy/your-product-variant-id

# 专注时长配置（可选，默认值）
FOCUS_MINUTES=1
LOCK_MINUTES=5
