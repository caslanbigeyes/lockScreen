# 服务器配置
PORT=3000
NODE_ENV=development

# 微信支付配置
# 在 https://pay.weixin.qq.com 获取
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_MCH_ID=your_merchant_id_here
WECHAT_API_KEY=your_api_key_here
WECHAT_NOTIFY_URL=https://your-domain.com/api/payment/wechat/notify

# 支付宝配置
# 在 https://open.alipay.com 获取
ALIPAY_APP_ID=your_alipay_app_id_here
ALIPAY_PRIVATE_KEY=your_private_key_here
ALIPAY_PUBLIC_KEY=alipay_public_key_here
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/alipay/notify

# 邮件配置（可选）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@focusguard.com
SMTP_PASS=your_email_password

# 数据库配置（可选，默认使用内存存储）
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=focusguard
# DB_USER=root
# DB_PASS=password
